<mujoco model="invert pendulum">
     <asset>
    <texture type="2d" name="groundplane" builtin="checker"
             rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
             markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="mat_ground" texture="groundplane" texuniform="true"
              texrepeat="5 5" reflectance="0"/>
</asset>
     <compiler coordinate="local" inertiafromgeom="true"/>
  <option timestep="0.002" gravity="0 0 -9.81"/>
  <worldbody>
      <light name="top_light"
       pos="0 0 5"
       dir="0 0 -1"
       diffuse="1 1 1"
       specular="0.5 0.5 0.5"
       castshadow="false"/>
      <geom name="floor" type="plane" size="0 0 0.05" material="mat_ground"/>
    <body name="cart" pos="0 0 0.1">
      <joint name="slider" type="slide" axis="1 0 0" pos="0 0 0" limited="true"  range="-5 5" damping = "0.1"/>
      <geom name="cart" type="box" size="0.3 0.2 0.1" mass="0.5" rgba="0.2 0.6 0.8 1"/>
      <site name="cart_site" pos="0 0 0"/>
      <body name="pole" pos="0 0 0">
        <joint name="hinge" type="hinge" axis="0 1 0" pos="0 0 0"/>
        <geom name="pole" type="capsule" fromto="0 0 0 0 0 0.5" size="0.02" mass="0.1" rgba="0.8 0.2 0.2 1"/>
        <site name="tip_site" pos="0 0 0.5"/>
      </body>
    </body>
  </worldbody>
<actuator>
    <motor name="motor" joint="slider" gear="10" ctrllimited="true" ctrlrange="-10 10"/>
  </actuator>
    <sensor>
    <jointpos name="cart_pos" joint="slider"/>
    <jointvel name="cart_vel" joint="slider"/>
    <jointpos name="pole_angle" joint="hinge"/>
    <jointvel name="pole_angvel" joint="hinge"/>
  </sensor>
</mujoco>

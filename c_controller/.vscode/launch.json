{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "C Controller (gdb)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/controller.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [
                {"name": "PATH", "value": "D:/Software/Mujoco/bin;C:/Users/Administrator/AppData/Local/Programs/Python/Python314/Lib/site-packages/mujoco;${env:PATH}"}
            ],
            "externalConsole": true,
            "MIMode": "gdb",
            "miDebuggerPath": "D:/Toolchain/mingw64/bin/gdb.exe",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "build controller"
        }
    ]
}
